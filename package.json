{
  "name": "mural",
  "version": "1.0.0",
  "description": "Mural — porta-retrato digital para iPad (Capacitor + iOS)",
  "private": true,
  "scripts": {
    "dev": "node scripts/watch-dev.mjs",
    "dev:server": "node scripts/sync-www.mjs && python3 scripts/dev-server.py",
    "sync:www": "node scripts/sync-www.mjs",
    "cap:sync": "npm run sync:www && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios:build": "npm run cap:sync"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/preferences": "^7.0.1",
    "photo-library": "file:plugins/photo-library"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0"
  },
  "capacitor": {
    "platforms": [
      "ios"
    ]
  }
}
